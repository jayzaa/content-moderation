# Copy this file to .env (already gitignored) and fill in real values.
# NEVER commit a filled-in .env or any credential file to version control.
#
# The app loads .env automatically at startup (internal/config/dotenv.go).
# Real process/shell environment variables always take precedence over
# values in this file.

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------

# Address the Go server binds to. Keep this on localhost; put nginx (or
# another reverse proxy) in front of it — see nginx/image-detection.conf.
LISTEN_ADDR=127.0.0.1:8080

# ---------------------------------------------------------------------------
# API authorization
# ---------------------------------------------------------------------------

# Single bearer token required on all /api/* requests:
#   Authorization: Bearer <API_BEARER_TOKEN>
# Generate a strong random value, e.g.: openssl rand -hex 32
API_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Google Cloud Storage (temporary object storage for moderation)
# ---------------------------------------------------------------------------

# GCP project that owns the bucket below.
GCP_PROJECT_ID=

# GCS bucket used for temporary uploads. The service account below must
# have permission to create/read/delete objects in this bucket. Objects
# are deleted immediately after moderation completes (success or failure);
# nothing is retained long-term.
GCS_BUCKET=

# Path to a GCP service account JSON key file. The service account needs
# Storage Object Admin (or equivalent create/read/delete) on GCS_BUCKET.
# Keep this file outside the repository; never commit it.
GCS_CREDENTIALS_FILE=/path/to/service-account.json

# How long each generated signed URL remains valid, in minutes. Keep this
# short — it's the window during which the temporary object is fetchable
# by anyone with the URL (including Alibaba Cloud's moderation service).
SIGNED_URL_EXPIRY_MINUTES=10

# ---------------------------------------------------------------------------
# Alibaba Cloud Content Moderation (Green/CIP, API version 2022-03-02)
# ---------------------------------------------------------------------------

# RAM user AccessKey with AliyunYundunGreenWebFullAccess permission.
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# Region for the Green/CIP content moderation endpoint.
# Options include: ap-southeast-1 (Singapore), cn-shanghai, cn-beijing,
# us-east-1, eu-central-1. Defaults to ap-southeast-1 if unset.
# Note: video moderation (videoDetection_global) requires the Singapore
# region and a separately-activated product in the Alibaba Cloud console.
ALIBABA_CLOUD_REGION_ID=ap-southeast-1

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Directory (relative to the project root, or absolute) where each API
# call's result (raw response + summary + timestamp) is persisted as JSON.
# Viewable via the htdocs logs page / GET /api/logs.
LOGS_DIR=logs
